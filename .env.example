ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: override the default model used by the agent.
# ANTHROPIC_MODEL=claude-opus-4-5

# Default scout scoring backend.
# Supported values: auto, cerebras, ollama_cloud, openai_compatible, deepseek, gemini, claude, openrouter, lmstudio
# auto tries configured providers in AI_BACKEND_ORDER until one succeeds.
AI_BACKEND=auto
AI_BACKEND_ORDER=cerebras,ollama_cloud,gemini
# When a hosted provider rate-limits, auto mode skips it for this many seconds
# before trying that provider again.
HOSTED_RATE_LIMIT_COOLDOWN_SECONDS=90

# Preferred hosted scorer. Cerebras currently lists gpt-oss-120b as the stable
# public production model; override CEREBRAS_MODEL if your account exposes another model.
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_MAX_OUTPUT_TOKENS=512
CEREBRAS_MAX_ATTEMPTS=3

# Optional Ollama Cloud scorer. Direct cloud API access uses https://ollama.com/api.
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_MAX_OUTPUT_TOKENS=512
OLLAMA_MAX_ATTEMPTS=3
# Ollama Cloud currently documents structured outputs as unsupported.
# Leave false for Cloud; set true only for local/future Ollama endpoints that support JSON schema format.
OLLAMA_STRUCTURED_OUTPUTS=false

# Optional generic OpenAI-compatible scorer for experiments such as OpenCode Zen / Big Pickle.
OPENAI_COMPATIBLE_API_KEY=your_provider_api_key_here
OPENAI_COMPATIBLE_BASE_URL=https://provider.example/v1
OPENAI_COMPATIBLE_MODEL=provider-model-id

# Default Google AI Studio / Gemini API backend for scout scoring.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=512
# Use 0 for fast, low-quota scoring on Gemini 2.5 Flash. Use "auto" to omit.
GEMINI_THINKING_BUDGET=0
GEMINI_MAX_ATTEMPTS=3

# Optional local LM Studio backend for scout scoring.
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=google/gemma-4-e4b
LMSTUDIO_REASONING_ENABLED=false
LMSTUDIO_REASONING_EFFORT=none

# Optional OpenRouter backend for scout scoring.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_MAX_OUTPUT_TOKENS=512
OPENROUTER_MAX_ATTEMPTS=3

# Optional secure dashboard access credentials (Basic Authentication)
# Set these to protect the dashboard when exposed to the public internet.
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=your_secure_password_here

# Optional outbound scraping proxies to bypass datacenter IP restrictions on cloud hosts.
# SCRAPING_PROXY_SERVER=http://proxy.example.com:8000
# SCRAPING_PROXY_USERNAME=your_proxy_user
# SCRAPING_PROXY_PASSWORD=your_proxy_pass

